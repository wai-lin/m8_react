{
	"name": "react",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"packageManager": "pnpm@10.5.2",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"test": "vitest",
		"preview": "vite preview",
		"format": "prettier --write .",
		"typecheck": "tsc --noEmit",
		"lint": "eslint .",
		"lint-fmt": "prettier --check .",
		"depcheck": "knip --dependencies",
		"check-all": "pnpm typecheck && pnpm lint && pnpm lint-fmt && pnpm depcheck"
	},
	"imports": {
		"#types": "./src/types.ts",
		"#src/*": "./src/*"
	},
	"dependencies": {
		"@tanstack/react-query": "^5.90.21",
		"classnames": "^2.5.1",
		"date-fns": "^4.1.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-router": "^7.13.1"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^24.10.1",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.1",
		"eslint": "^9.39.1",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.4.24",
		"globals": "^16.5.0",
		"jsdom": "^28.1.0",
		"knip": "^5.86.0",
		"prettier": "^3.8.1",
		"prettier-plugin-organize-imports": "^4.3.0",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.48.0",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	}
}
